# Notion API token. Required for all syncs and the kanbanEvent webhook.
# Create an internal integration at:
#   https://www.notion.so/profile/integrations/internal
NOTION_API_TOKEN=

# Discord bot token. Required for projectsFromDiscord sync and channel-management tools.
DISCORD_BOT_TOKEN=

# Discord guild (server) ID. Replaces the hardcoded default in scripts/seed-board-map.ts.
AGENTIC_GUILD_ID=

# GitHub PAT with `gist` scope. Used by tasksDelta / tasksBackfill to fetch the kanban snapshot.
# GIST_TOKEN is accepted as a fallback alias.
GITHUB_TOKEN=

# Gist ID hosting the kanban tasks snapshot (published by the local kanban hook).
KANBAN_TASKS_GIST_ID=

# Shared secret for HMAC-SHA256 verification of inbound kanbanEvent webhook requests.
# Header: x-kanban-signature-256: sha256=<hex>
KANBAN_WEBHOOK_SECRET=

# Notion database / data-source IDs used by tools that write directly via context.notion
# (upsertTask, tombstoneTask, bindProjectToBoard).
PROJECTS_DATABASE_ID=
PROJECTS_DATA_SOURCE_ID=
TASKS_DATABASE_ID=
TASKS_DATA_SOURCE_ID=
