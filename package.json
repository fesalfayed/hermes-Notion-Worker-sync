{
	"name": "hermes-projects-sync",
	"version": "1.0.0",
	"description": "Bidirectional Discord ↔ Notion sync built on @notionhq/workers — mirrors Discord channels into Notion databases",
	"private": true,
	"keywords": ["notion", "discord", "sync", "kanban", "workers"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/fesalfayed/hermes-projects-sync.git"
	},
	"scripts": {
		"build": "tsc && node -e \"require('fs').copyFileSync('board_channel_map.yaml','dist/board_channel_map.yaml')\"",
		"check": "tsc --noEmit",
		"onboard": "bash scripts/onboard.sh"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.9.2"
	},
	"devDependencies": {
		"@types/node": "^22.9.0",
		"tsx": "^4.20.6",
		"typescript": "^5.8.0"
	},
	"dependencies": {
		"@notionhq/workers": ">=0.0.0",
		"yaml": "^2.9.0"
	}
}
